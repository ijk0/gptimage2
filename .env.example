# Base URL of the gpt-image-2 API (without trailing /images/generations).
# Example: https://api.openai.com/v1
IMAGE_API_URL=

# Bearer token for the API.
IMAGE_API_KEY=

# Optional: model name sent to the API. Defaults to gpt-image-2.
# IMAGE_MODEL=gpt-image-2

# Optional: free per-visitor generation limit (tracked via HttpOnly cookie).
# Defaults to 5. Set to a very large number to effectively disable.
# FREE_LIMIT=5
